# Coach V serverless proxy. Copy to .env.local for `vercel dev`,
# and set the same key in Vercel Project Settings, Environment Variables.
# The key stays server-side; the deployed site never exposes it, so judges
# use Coach V with no key of their own.
#
# Google Gemini API key (free tier via Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...
